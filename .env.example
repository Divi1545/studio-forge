# --- Core ---
DATABASE_URL="postgresql://studioforge:studioforge@localhost:5432/studioforge"
REDIS_URL="redis://localhost:6379"

# Single-admin auth (no signup flow). SESSION_SECRET must be >= 32 characters.
ADMIN_PASSWORD="change-me"
SESSION_SECRET="change-me-to-a-random-32-plus-character-string"

# --- AI reasoning (Anthropic only, never OpenAI) ---
ANTHROPIC_API_KEY=""
# Master spec references "claude-sonnet-4-6", which is not a real Anthropic model ID.
# Defaults to the current Sonnet model; override here once the intended model is confirmed.
ANTHROPIC_MODEL="claude-sonnet-5"

# --- Generation providers (behind the router, never called directly from routes) ---
FAL_KEY=""
ELEVENLABS_API_KEY=""
SUNO_API_KEY=""

# --- Storage: S3-compatible (MinIO locally, Cloudflare R2 in production) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY="studioforge"
S3_SECRET_KEY="studioforge-secret"
S3_BUCKET="studioforge"

# --- Authority13 integration (peer platform) ---
AUTHORITY13_URL=""
AUTHORITY13_API_KEY=""

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
